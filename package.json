{
	"name": "@cvsa/prisma-zod",
	"module": "dist/index.js",
	"version": "3.4.1",
	"type": "module",
	"private": false,
	"license": "MIT",
	"repository": {
		"url": "https://github.com/project-cvsa/prisma-zod-generator"
	},
	"bin": {
		"prisma-zod": "dist/index.js"
	},
	"scripts": {
		"format": "biome format --write .",
		"lint": "biome lint .",
		"biome:ci": "biome ci .",
		"test": "bunx --bun turbo test:raw",
		"test:raw": "bun test",
		"build": "bunx --bun turbo build:raw",
		"build:raw": "bun build.ts",
		"typecheck": "bunx --bun turbo typecheck",
		"typecheck:raw": "bunx --bun tsgo --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@prisma/dmmf": "^7.5.0",
		"@types/bun": "latest",
		"prisma": "^7.5.0",
		"prisma-json-types-generator": "^4.1.1",
		"turbo": "^2.8.20",
		"@typescript/native-preview": "^7.0.0-dev.20260327.2"
	},
	"peerDependencies": {
		"@prisma/client": ">= 7.0.0",
		"prisma": ">= 7.0.0",
		"zod": ">= 4.0.0"
	},
	"dependencies": {
		"@prisma/generator-helper": "^7.5.0"
	},
	"packageManager": "bun@1.3.11",
	"files": [
		"dist/"
	]
}
