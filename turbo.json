{
	"$schema": "https://turbo.build/schema.json",
	"remoteCache": {
		"enabled": true
	},
	"tasks": {
		"build:raw": {
			"inputs": ["src/**.ts", "./build.ts"],
			"outputs": ["dist/**"]
		},
		"test:raw": {
			"inputs": ["src/**.ts", "tests/**.ts", "tests/**.prisma"],
			"dependsOn": ["build:raw"]
		}
	}
}
