datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client"
    output   = "./generated"
}

generator zod {
    provider     = "bun ../../dist/index.js"
    output       = "./zod"
    dateSchema = "string"
}

model User {
    id        BigInt   @id @default(autoincrement())
    email     String   @unique
    name      String?
    posts     Post[]
    /// [number]
    createdAt DateTime @default(now())
    /// [number]
    updatedAt DateTime @updatedAt()
}

model Post {
    id        BigInt   @id @default(autoincrement())
    title     String
    content   String?
    published Boolean  @default(false)
    author    User     @relation(fields: [authorId], references: [id])
    authorId  BigInt
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt()
}
