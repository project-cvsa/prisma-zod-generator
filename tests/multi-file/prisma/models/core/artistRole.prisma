model ArtistRole {
    id             Int        @id @default(autoincrement())
    role           String
    localizedRoles Json?      @map("localized_roles")
    creations      Creation[]
    createdAt      DateTime   @default(now()) @map("created_at")
    updatedAt      DateTime   @updatedAt @map("updated_at")
    deletedAt      DateTime?  @map("deleted_at")

    @@map("artist_role")
    @@schema("core")
}
